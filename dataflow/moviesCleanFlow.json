{
	"name": "moviesCleanFlow",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "inputDataset",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "inputDataset",
						"type": "DatasetReference"
					},
					"name": "source2"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "outputDataset",
						"type": "DatasetReference"
					},
					"name": "sink1"
				},
				{
					"dataset": {
						"referenceName": "outputDataset",
						"type": "DatasetReference"
					},
					"name": "movieCntPerYearSink"
				}
			],
			"transformations": [
				{
					"name": "yearDerivedColumn"
				},
				{
					"name": "aggYear",
					"description": "Add aggregate columns, grouping year"
				},
				{
					"name": "sortMovieCount"
				},
				{
					"name": "union1"
				},
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          movieId as string,",
				"          title as string,",
				"          genres as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source(output(",
				"          movieId as string,",
				"          title as string,",
				"          genres as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source2",
				"union1 derive(year = toInteger(trim((right(title,6)), '()')),",
				"          title = toString(left(title, length(title)-6))) ~> yearDerivedColumn",
				"yearDerivedColumn aggregate(groupBy(year),",
				"     movieCount = count(),",
				"     partitionBy('hash', 1)) ~> aggYear",
				"aggYear sort(asc(movieCount, false)) ~> sortMovieCount",
				"source1, source2 union(byName: true)~> union1",
				"yearDerivedColumn derive(genres = split(genres, '|')) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['movies-csv'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1",
				"sortMovieCount sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['movieCount'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> movieCntPerYearSink"
			]
		}
	}
}